{
  "name": "zupper-ui",
  "version": "0.0.0",
  "private": true,
  "description": "Design system do Zupper — tokens (agnóstico) + componentes (RN agora, web no futuro).",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf packages/*/lib packages/*/dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.3.0",
    "typescript-eslint": "^8.0.0"
  },
  "overrides": {
    "ajv-keywords": {
      "ajv": "^8.17.1"
    },
    "react-native-web": {
      "react": "19.2.0",
      "react-dom": "19.2.0"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
