{
  "name": "zupper-ui",
  "version": "0.0.0",
  "private": true,
  "description": "Design system do Zupper — tokens (agnóstico) + componentes (RN agora, web no futuro).",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
