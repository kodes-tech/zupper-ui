{
  "name": "@kodes-tech/icons",
  "version": "0.2.0",
  "description": "Ícones do design system Zupper — SVGs crus (fonte da verdade) + componentes gerados por renderer: react-native-svg (native) e <svg> DOM (web). O bundler escolhe o renderer via exports.",
  "license": "UNLICENSED",
  "source": "src/native/index.ts",
  "main": "lib/commonjs/web/index.js",
  "module": "lib/module/web/index.js",
  "types": "lib/typescript/web/index.d.ts",
  "react-native": "src/native/index.ts",
  "exports": {
    ".": {
      "react-native": {
        "types": "./lib/typescript/native/index.d.ts",
        "default": "./src/native/index.ts"
      },
      "import": {
        "types": "./lib/typescript/web/index.d.ts",
        "default": "./lib/module/web/index.js"
      },
      "require": {
        "types": "./lib/typescript/web/index.d.ts",
        "default": "./lib/commonjs/web/index.js"
      },
      "default": "./lib/commonjs/web/index.js"
    },
    "./native": {
      "types": "./lib/typescript/native/index.d.ts",
      "react-native": "./src/native/index.ts",
      "import": "./lib/module/native/index.js",
      "require": "./lib/commonjs/native/index.js",
      "default": "./lib/commonjs/native/index.js"
    },
    "./web": {
      "types": "./lib/typescript/web/index.d.ts",
      "import": "./lib/module/web/index.js",
      "require": "./lib/commonjs/web/index.js",
      "default": "./lib/commonjs/web/index.js"
    },
    "./assets/*": "./assets/*",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "assets",
    "!**/*.stories.*",
    "!**/*.spec.*",
    "!**/__tests__"
  ],
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "prepack": "bob build",
    "test": "jest",
    "icons:generate": "node scripts/generate-icons.mjs",
    "icons:audit": "node scripts/audit-icons.mjs"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.72",
    "react-native-svg": ">=13"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.83.2",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jest": "^29.7.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-builder-bob": "^0.30.0",
    "react-native-svg": "^15.15.5",
    "typescript": "^5.4.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "exclude": "**/{__tests__,__fixtures__,__mocks__}/**",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}
