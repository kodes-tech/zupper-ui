{
  "name": "@kodes-tech/ui-native",
  "version": "0.1.1",
  "description": "Componentes React Native do design system Zupper (Community). Consome @kodes-tech/tokens.",
  "license": "UNLICENSED",
  "source": "src/index.ts",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "types": "./lib/typescript/index.d.ts",
      "react-native": "./src/index.ts",
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js",
      "default": "./lib/commonjs/index.js"
    }
  },
  "files": [
    "src",
    "lib",
    "!**/*.stories.*",
    "!**/*.spec.*",
    "!**/__tests__",
    "!src/_figma"
  ],
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "prepare": "tsc -p ../tokens/tsconfig.json && bob build",
    "test": "jest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "icons:audit": "node scripts/audit-icons.mjs",
    "icons:generate": "node scripts/generate-icon.mjs"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@kodes-tech/tokens": "^0.1.1"
  },
  "peerDependencies": {
    "nativewind": ">=4.1",
    "react": "*",
    "react-native": ">=0.72",
    "react-native-linear-gradient": ">=2.8",
    "react-native-reanimated": ">=3.6",
    "react-native-safe-area-context": ">=4.0",
    "react-native-svg": ">=13",
    "tailwindcss": ">=3.4 <4"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@react-native/babel-preset": "0.83.2",
    "@storybook/addon-essentials": "^8.3.0",
    "@storybook/react-webpack5": "^8.3.0",
    "@testing-library/react-native": "^12.5.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^7.1.2",
    "jest": "^29.7.0",
    "nativewind": "^4.1.23",
    "postcss": "^8.4.0",
    "postcss-loader": "^8.1.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-builder-bob": "^0.30.0",
    "react-native-linear-gradient": "2.8.3",
    "react-native-reanimated": "4.2.2",
    "react-native-safe-area-context": "5.6.2",
    "react-native-svg": "^15.15.5",
    "react-native-web": "^0.19.12",
    "react-native-web-linear-gradient": "^1.1.2",
    "react-native-worklets": "^0.8.0",
    "react-test-renderer": "19.2.0",
    "storybook": "^8.3.0",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "exclude": "**/{__tests__,__fixtures__,__mocks__,_figma}/**",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}
